#include<bits/stdc++.h>
using namespace std;

int main(){
    string s;
    cin>>s;
    int count = 0;
    vector<char>ans;
    set<char>ss;
    for(char str:s){
        if(ss.find(str) == ss.end()){
            ans.push_back(str);
            ss.insert(str);
            count++;
        }
    }
    if(count % 2 == 0){
        cout<<"CHAT WITH HER!";
    }
    else{
        cout<<"IGNORE HIM!";
    }
}
